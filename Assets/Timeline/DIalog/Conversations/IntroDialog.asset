%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 373ed9b9ff90bd34dbfd73261247c819, type: 3}
  m_Name: IntroDialog
  m_EditorClassIdentifier: 
  DialogEntries:
  - Talker: {fileID: 11400000, guid: 79808c029df8cdb4791e3dc773222f13, type: 2}
    Sentence:
    - '"Berita terkini! Wabah <b>Euphoria<b> semakin menyebar luas dan menginfeksi
      beberapa distrik Kota Pollis"'
    - '"Berikut kami sebutkan distrik-distrik terkini yang teridentifikasi zona bahaya
      infeksi <b>Euphoria<b> : distrik Ganx, distrik Altz, distrik Doir, distrik
      Amety, dan distrik Scram."'
    - '"Diharapkan untuk warga setempat untuk menjahui keramaian dan tidak ikut untuk
      tertawa bersama-""'
  - Talker: {fileID: 11400000, guid: 05e9dbadbaa6779419f19f523defd50b, type: 2}
    Sentence:
    - '*Suara static*'
  - Talker: {fileID: 11400000, guid: b1246281a6f32ad4aafa1ca5dd306b9f, type: 2}
    Sentence:
    - '"--aku terkenal! Aku akan jadi terkenal!"'
    - '"Kamera masuk? Aahaha! Baiklah, ehem, berita terkini. Berita terkini!"'
    - '"Melapor dari tempat kejadian perkara, hari ini, orang-orang berpesta-pora
      menikmati pesta hidangan lezat di sepanjang jalan distrik Ganx."'
  - Talker: {fileID: 11400000, guid: 05e9dbadbaa6779419f19f523defd50b, type: 2}
    Sentence:
    - '"Televisi menayangkan bagaimana orang-orang melukai sesamanya dan memakan
      satu sama lain"'
    - '"Toko-toko pinggir jalan dirampok oleh banyak orang. Emas, makanan, pakaian,
      dan benda lainnya. Orang-orang mengambil barang rampokan sambil terbahak sebelum
      saling melukai satu sama lain dan saling rebut"'
    - '"Jeritan orang-orang yang tercampur dengan tawa kencang yang tak manusiawi
      terdengar dari berbagai arah. Dunia seperti tenggelam dalam kekacauan dan kegilaan
      yang tampak ''menyenangkan''."'
  - Talker: {fileID: 11400000, guid: b1246281a6f32ad4aafa1ca5dd306b9f, type: 2}
    Sentence:
    - '"Bisa dilihat, bagaimana disini mereka-hey! Lepaskan aku!"'
