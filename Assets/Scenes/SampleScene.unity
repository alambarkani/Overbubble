  bedDialogs:
  - characterName: You
    text: "\u201CRasanya penat juga berlagak sok pahlawan begini. Menyelamatkan dunia
      yang tak sedikit pun memerdulikanku. Bukannya ini pekerjaan sia-sia yang bodoh?\u201D"
  - characterName: You
    text: "\u201CKalau dipikir-pikir lagi\u2026 menyelamatkan diri sendiri juga ribet.
      Lagipula, siapa yang peduli kalau aku ikut gila seperti mereka?\u201D"
  - characterName: You
    text: "\u201CTapi\u2026 apa itu yang sebenarnya kuinginkan?\u201D"
  choiceContainer: {fileID: 997946588}
