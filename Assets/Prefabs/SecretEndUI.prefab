--- !u!114 &977331898771733548
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2736080600653127961}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: c5c9b0342b87fbc49a5069066164bd83, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  typingSpeed: 0.1
  pauseBetweenTexts: 1
  textEvents:
  - text: Entah sudah berapa lama aku tertidur.
    onTextComplete:
      m_PersistentCalls:
        m_Calls: []
  - text: Saat terbangun dari kasur, aku merasa begitu ringan dan senang, seakan
      semua penatku menghilang.
    onTextComplete:
      m_PersistentCalls:
        m_Calls: []
  - text: Saat aku berjalan keluar kamar, aku melihat dunia ini hanya dipenuhi makhluk-makhluk
      tersenyum dan tertawa begitu menjengkelkan.
    onTextComplete:
      m_PersistentCalls:
        m_Calls: []
  - text: Aku melihat pentungan paha ayam berwarna terang disampingku.
    onTextComplete:
      m_PersistentCalls:
        m_Calls: []
  - text: Kugunakan benda itu untuk memukul kepala makhluk-makhluk yang tertawa itu
      seperti permainan memukul tikus tanah.
    onTextComplete:
      m_PersistentCalls:
        m_Calls: []
  - text: Ini benar-benar menyenangkan!
    onTextComplete:
      m_PersistentCalls:
        m_Calls: []
  audioSource: {fileID: 0}
  typingSound: {fileID: 8300000, guid: 845514a6d0e33e4498e54363d5b3e1a2, type: 3}
  button: {fileID: 1008167920578272170}
