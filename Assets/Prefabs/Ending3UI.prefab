--- !u!114 &4665451748094769369
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 7977248402256953041}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: c5c9b0342b87fbc49a5069066164bd83, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  typingSpeed: 0.1
  pauseBetweenTexts: 1
  textEvents:
  - text: Aku kira keluar dari kota gila itu dan membinasakan wabah Euphoria sekaligus
      sudah jadi awal dari hidup damai ku.
    onTextComplete:
      m_PersistentCalls:
        m_Calls: []
  - text: Tapi aku salah.
    onTextComplete:
      m_PersistentCalls:
        m_Calls: []
  - text: "Entah apa yang terjadi di dunia ini. Semua orang seperti punya wabah kegilaannya
      sendiri\u2013hanya karena mereka berbeda daerah."
    onTextComplete:
      m_PersistentCalls:
        m_Calls: []
  - text: "Dan wabah kota baru ini\u2026 jauh lebih mengerikan daripada Kota Pollis."
    onTextComplete:
      m_PersistentCalls:
        m_Calls: []
