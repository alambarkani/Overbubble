--- !u!114 &1705824408064407575
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 4435503716130129518}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: c5c9b0342b87fbc49a5069066164bd83, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  typingSpeed: 0.1
  pauseBetweenTexts: 1
  textEvents:
  - text: Pemerintah berhasil mengetahui lokasi ku setelah berulang kali gagal meretas
      sistem mereka.
    onTextComplete:
      m_PersistentCalls:
        m_Calls: []
  - text: Sebagai hukumannya, aku dilemparkan ke keramaian Euphorian dan menjadi
      salah satu dari mereka.
    onTextComplete:
      m_PersistentCalls:
        m_Calls: []
  - text: Pertama kalinya dalam hidupku bisa berpesta pora seperti ini.
    onTextComplete:
      m_PersistentCalls:
        m_Calls: []
  - text: Hidangan dan cemilan enak dihamburkan ke udara, mewarnai jalanan dengan
      warna-warni terangnya.
    onTextComplete:
      m_PersistentCalls:
        m_Calls: []
  - text: Rasa laparku seakan tak tertahankan.
    onTextComplete:
      m_PersistentCalls:
        m_Calls: []
  - text: Tanpa sadar, aku mengusap saus tomat yang jatuh di jalanan dan mengecapnya.
    onTextComplete:
      m_PersistentCalls:
        m_Calls: []
  - text: ' Ini enak sekali...'
    onTextComplete:
      m_PersistentCalls:
        m_Calls: []
  audioSource: {fileID: 0}
  typingSound: {fileID: 8300000, guid: c4093814bff9be847be2e16c8cb671f4, type: 3}
  button: {fileID: 6165027680466125413}
