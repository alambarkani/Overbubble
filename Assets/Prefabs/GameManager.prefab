  secretEndUI: {fileID: 0}
  startUI: {fileID: 0}
  secretEndDialogs:
  - characterName: You
    text: '"Sudah cukup menonton TV nya. Rasanya aku ingin muntah"'
  - characterName: You
    text: '"<b>Euphoria</b> punya gejala-gejala tertentu untuk setiap orang yang
      terinfeksi. Kalau tidak salah, aku sudah menuliskannya di <b>buku tulis</b>
      diatas <b>kasur</b>"'
  - characterName: You
    text: '"Tapi kalau tidak ingin buang-buang waktum lebih baik aku memulai <b>Hack
      Satelite System</p> sekarang."'
  - characterName: You
    text: '"Aku tak peduli jika harus membungihanguskan semuanya daripada wabah ini
      terus menyebar. Kegilaan ini harus segera diakhiri.""'
  - characterName: You
    text: '"Tinggal 24 jam lagi... apa aku bisa melakukannya sebelum saat itu?"'
  currentChapter: 1
