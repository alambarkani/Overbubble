MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 157897140203687557}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 630a6adae1c05314389b8a0fbe6b4471, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  tvStaticDialogs:
  - characterName: Penyiar Berita
    text: '"Berita terkini! Wabah <b>Euphoria<b> semakin menyebar luas dan menginfeksi
      beberapa distrik Kota Pollis"'
  - characterName: Penyiar Berita
    text: '"Berikut kami sebutkan distrik-distrik terkini yang teridentifikasi zona
      bahaya infeksi <b>Euphoria<b> : distrik Ganx, distrik Altz, distrik Doir, distrik
      Amety, dan distrik Scram."'
  - characterName: Penyiar Berita
    text: '"Diharapkan untuk warga setempat untuk menjahui keramaian dan tidak ikut
      untuk tertawa bersama-""'
  - characterName: ???
    text: shzsh
  - characterName: Reporter
    text: '"--aku terkenal! Aku akan jadi terkenal!"'
  - characterName: Reporter
    text: '"Kamera masuk? Aahaha! Baiklah, ehem, berita terkini. Berita terkini!"'
  - characterName: Reporter
    text: '"Melapor dari tempat kejadian perkara, hari ini, orang-orang berpesta-pora
      menikmati pesta hidangan lezat di sepanjang jalan distrik Ganx."'
  - characterName: Narator (sistem)
    text: '"Televisi menayangkan bagaimana orang-orang melukai sesamanya dan memakan
      satu sama lain"'
  - characterName: Narator (sistem)
    text: '"Toko-toko pinggir jalan dirampok oleh banyak orang. Emas, makanan, pakaian,
      dan benda lainnya. Orang-orang mengambil barang rampokan sambil terbahak sebelum
      saling melukai satu sama lain dan saling rebut"'
  - characterName: Narator (sistem)
    text: '"Jeritan orang-orang yang tercampur dengan tawa kencang yang tak manusiawi
      terdengar dari berbagai arah. Dunia seperti tenggelam dalam kekacauan dan kegilaan
      yang tampak ''menyenangkan''."'
  - characterName: Reporter
    text: '"Bisa dilihat, bagaimana disini mereka-hey! Lepaskan aku!"'
  afterTVStaticDialogs:
  - characterName: You
    text: '"Sudah cukup menonton TV nya. Rasanya aku ingin muntah"'
  - characterName: You
    text: '"<b>Euphoria</b> punya gejala-gejala tertentu untuk setiap orang terinfeksi.
      Kalau tidak salah, aku sudah menuliskannya di <b>buku tulis</b> diatas <b>kasur</b>"'
  - characterName: You
    text: '"Tapi kalau tidak ingin buang-buang waktu, lebih baik aku memulai <b>Hack
      Satelite System</b> ku sekarang"'
  - characterName: You
    text: '"Aku tak peduli jika harus membumihanguskan semuanya daripada wabah ini
      terus menyebar. Kegilaan ini lebih baik harus segera diakhiri."'
  - characterName: You
    text: '"Tinggal 24 jam lagi... apa aku bisa melakukannya sebelum saat itu?"'
